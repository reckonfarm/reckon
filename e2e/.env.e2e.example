# Copy to .env.e2e (gitignored) and fill in.
# The preview deploy URL Playwright targets (Preview env has EMAILS_DISABLED=1).
E2E_BASE_URL=https://<your-preview>.vercel.app
# Vercel "Protection Bypass for Automation" secret — sent as x-vercel-protection-bypass.
VERCEL_BYPASS=<bypass-secret>
# Supabase URL + SERVICE_ROLE + ANON are read from ../.env.local automatically.
